{
	"name": "embed-youtube-component",
	"version": "2.3.2",
	"description": "A Web Component for embedding YouTube videos on your site in a GDPR-compliant way. By setting certain parameters, nothing is fetched from Google’s servers until the user clicks Play on the video.",
	"author": {
		"name": "Lorenzo Saibal Forti",
		"email": "lorenzo.forti@gmail.com"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saiballo/embed-youtube-component"
	},
	"engines": {
		"node": ">=16.0.0"
	},
	"scripts": {
		"install:linter": "node _bundler/bundler.install.js linter",
		"uninstall:linter": "node _bundler/bundler.install.js linter-remove",
		"gulp": "cross-env NODE_PREPROS=false gulp",
		"gulp:assets:rev": "gulp revisioningAssets",
		"gulp:assets:size": "gulp sizeAssets --silent",
		"gulp:open": "cross-env NODE_PREPROS=false gulp --open",
		"gulp:proxy": "cross-env NODE_PREPROS=false NODE_BROWSER_PROXY=true gulp --server=proxy",
		"gulp:proxy:open": "cross-env NODE_PREPROS=false NODE_BROWSER_PROXY=true gulp --server=proxy --open",
		"dev": "npm run gulp",
		"dev:open": "npm run gulp:open",
		"dev:proxy": "npm run gulp:proxy",
		"dev:proxy:open": "npm run gulp:proxy:open",
		"compile": "cross-env NODE_PREPROS=false gulp compile",
		"compile:build": "cross-env NODE_ENV=production NODE_PREPROS=false gulp build && npm run gulp:assets:size",
		"build": "npm run compile:build && npm run gulp:assets:rev",
		"serve": "cross-env NODE_PREPROS=false NODE_ONLY_SERVE=true gulp serveStandalone",
		"serve:open": "cross-env NODE_PREPROS=false NODE_ONLY_SERVE=true gulp --open serveStandalone",
		"copy:assets": "gulp copyAssets",
		"copy:assets:clean": "gulp copyAssets --clean",
		"linter:js": "node ./_bundler/linter/linter.init.js --eslint",
		"linter:js:all": "node ./_bundler/linter/linter.init.js --eslint \"./src/js/*.js\"",
		"linter:node": "node ./_bundler/linter/linter.init.js --eslint --node",
		"linter:scss": "node ./_bundler/linter/linter.init.js --stylelint",
		"linter:scss:all": "node ./_bundler/linter/linter.init.js --stylelint \"./src/scss/**/*.scss\"",
		"clean": "rm -rf ./docs/assets/css/* ./docs/assets/js/* ./docs/*.html",
		"clean:css": "rm -rf ./docs/assets/css/*",
		"clean:js": "rm -rf ./docs/assets/js/*",
		"clean:all": "echo 'Sei sicuro di voler cancellare tutta la directory docs? [s/N]' && read -r risposta && [[ \"$risposta\" =~ ^[Ss]$ ]] && rm -rf docs || echo 'Operazione annullata'"
	},
	"devDependencies": {
		"autoprefixer": "^10.4.27",
		"browser-sync": "^3.0.4",
		"cross-env": "^10.1.0",
		"cssnano": "^7.1.2",
		"del": "^8.0.1",
		"esbuild": "^0.27.3",
		"esbuild-minify-templates": "^0.13.1",
		"esbuild-plugin-alias": "^0.2.1",
		"esbuild-plugin-replace": "^1.4.0",
		"fast-glob": "^3.3.3",
		"gulp": "^5.0.1",
		"gulp-plumber": "^1.2.1",
		"gulp-postcss": "^10.0.0",
		"gulp-rename": "^2.1.0",
		"gulp-rev-all": "^4.1.1",
		"gulp-sass": "^6.0.1",
		"gulp-sass-glob-import": "^0.1.0",
		"gulp-size": "^5.0.0",
		"gulp-sourcemaps": "^3.0.0",
		"micromatch": "^4.0.8",
		"purgecss": "^8.0.0",
		"sass": "^1.97.3",
		"through2": "^4.0.2",
		"yargs": "^18.0.0"
	},
	"devOptionalLinter": {
		"eslint": "^10.0.0",
		"globals": "^17.3.0",
		"eslint-plugin-html": "^8.1.4",
		"@stylistic/eslint-plugin": "^5.7.1",
		"stylelint": "^17.1.1",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.0.0",
		"stylelint-order": "^7.0.1",
		"@stylistic/stylelint-plugin": "^5.0.1"
	}
}
